{
  "name": "@haxtheweb/haxcms-nodejs",
  "version": "26.0.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "HAXcms single and multisite nodejs server, api, and administration",
  "main": "dist/index.js",
  "icon": "./dist/favicon.ico",
  "scripts": {
    "dev:build": "npm run build && nodemon dist/app.js",
    "dev": "nodemon src/app.js",
    "dev:nologin": "nodemon src/local.js",
    "dev:linked-assets": "NODE_ENV=development HAXCMS_WEBCOMPONENTS_ROOT=../webcomponents npm start",
    "start": "node scripts/start-with-auto-open.js",
    "build": "rm -rf dist && babel src --out-dir dist --copy-files --include-dotfiles && chmod 774 dist/local.js && chmod 774 dist/app.js && chmod 774 dist/cli.js",
    "verify:sanitize-policy": "node scripts/verify-sanitize-policy.js",
    "test:api-conformance": "node --test test/api-conformance/**/*.test.cjs",
    "release": "npm run build && commit-and-tag-version && git push --follow-tags origin main && npm publish",
    "haxcms-nodejs-cli": "haxcms-nodejs-cli"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/haxtheweb/haxcms-nodejs.git"
  },
  "bugs": {
    "url": "https://github.com/haxtheweb/issues/issues"
  },
  "bin": {
    "haxcms-nodejs": "./dist/local.js",
    "haxcms-nodejs-cli": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://hax.psu.edu/",
  "keywords": [
    "haxtheweb",
    "haxcms",
    "haxsite",
    "htw",
    "webcomponents",
    "lit"
  ],
  "author": "HAXTheWeb core team",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.20.3"
  },
  "dependencies": {
    "archiver": "8.0.0",
    "axios": "^1.16.0",
    "chokidar": "5.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dompurify": "3.3.0",
    "dotenv": "16.4.5",
    "express": "^4.22.2",
    "fs-extra": "11.2.0",
    "git-interface": "2.1.2",
    "helmet": "7.1.0",
    "js-yaml": "4.1.1",
    "jsonwebtoken": "9.0.3",
    "jsdom": "26.1.0",
    "locutus": "^3.0.34",
    "mime": "3.0.0",
    "minimist": "1.2.8",
    "multer": "2.1.1",
    "node-html-parser": "7.1.0",
    "open": "8.4.2",
    "sharp": "0.32.6",
    "text-readability": "1.1.1",
    "turndown": "7.1.1",
    "twig": "^3.0.0",
    "utf8": "3.0.0",
    "uuid": "11.1.1",
    "ws": "8.20.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@babel/cli": "7.28.6",
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.5",
    "@babel/register": "7.29.3",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "babel-plugin-transform-dynamic-import": "2.1.0",
    "commit-and-tag-version": "12.7.3",
    "nodemon": "3.1.14"
  }
}
